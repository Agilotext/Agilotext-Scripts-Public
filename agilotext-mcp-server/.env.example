# Copier vers .env et remplir (ne jamais committer .env)

# Obligatoire pour le serveur MCP Agilotext (voir src/config.ts)
AGILOTEXT_USERNAME=you@example.com
AGILOTEXT_TOKEN=
AGILOTEXT_EDITION=ent

# Optionnel — URL API (défaut ci-dessous)
# AGILOTEXT_API_URL=https://api.agilotext.com/api/v1

# Scripts / curl / getAuthToken uniquement — mot de passe ADMIN Agilotext (PAS le mot de passe du compte client).
# Le serveur MCP actuel ne lit PAS cette variable ; elle sert aux appels POST /getAuthToken hors MCP.
AGILOTEXT_ADMIN_PASSWORD=
